      ],
      "identity_fields": [
        "address_street",
        "address_city",
        "sale_date",
        "sale_price"
      ]
    },
    "lease": {
      "required": [
        "address_street",
        "base_rent_psf"
      ],
      "recommended": [
        "address_city",
        "tenant_name",
        "lease_date",
        "sf_leased",
        "rent_structure"
      ],
      "identity_fields": [
        "address_street",
        "address_city",
        "tenant_name",
        "lease_date",
        "sf_leased",
        "base_rent_psf"
      ]
    }
  },
  "confidence_values": [
    "high",
    "medium",
    "low",
    "unknown"
  ],
  "review_statuses": [
    "unreviewed",
    "confirmed",
    "rejected"
  ],
